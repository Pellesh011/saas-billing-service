# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/billing
POSTGRES_PASSWORD=postgres

# Redis
REDIS_URL=redis://localhost:6379

# Keycloak (backend connection)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=billing
KEYCLOAK_CLIENT_ID=backend
KEYCLOAK_CLIENT_SECRET=backend-secret-change-in-production
KEYCLOAK_CLIENT_ID_FRONTEND=frontend

# Keycloak admin credentials (for docker-compose bootstrap)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Frontend
VITE_API_URL=http://localhost:3001
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=billing
VITE_KEYCLOAK_CLIENT_ID=frontend

# Email (optional - for notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@example.com
