version: '3.8'

services:
  postgres:
    ports:
      - "5432:5432"
    environment:
      POSTGRES_PASSWORD: postgres

  redis:
    ports:
      - "6379:6379"

  backend:
    build:
      target: development
    volumes:
      - ./apps/backend:/app
      - /app/node_modules
    command: npm run dev
    environment:
      NODE_ENV: development
      DATABASE_URL: postgresql://postgres:postgres@postgres:5432/billing
      REDIS_URL: redis://redis:6379

  frontend:
    build:
      target: development
    volumes:
      - ./apps/frontend:/app
      - /app/node_modules
    command: npm run dev
    environment:
      VITE_API_URL: http://localhost:3001/api

  worker:
    build:
      target: development
    volumes:
      - ./apps/backend:/app
      - /app/node_modules
    command: npm run worker:dev
